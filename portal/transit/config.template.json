{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "dns-google",
        "address": "8.8.8.8",
        "detour": "do-out"
      }
    ],
    "rules": [
      {
        "query_type": [ "AAAA" ],
        "action": "reject"
      }
    ],
    "final": "dns-google"
  },
  "inbounds": [
    {
      "type": "vless",
      "tag": "vless-in",
      "listen": "::",
      "listen_port": 443,
      "users": [
        {
          "uuid": "{UUID}",
          "flow": "xtls-rprx-vision"
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "www.microsoft.com",
        "reality": {
          "enabled": true,
          "handshake": {
            "server": "www.microsoft.com",
            "server_port": 443
          },
          "private_key": "{PRIVATE_KEY}",
          "short_id": [ "{SHORT_ID}" ]
        }
      },
      "sniff": true,
      "sniff_override_destination": true
    }
  ],
  "outbounds": [
    {
      "type": "socks",
      "tag": "portal-out",
      "server": "{PROXY_IP}",
      "server_port": "{PROXY_PORT}",
      "username": "{PROXY_USERNAME}",
      "password": "{PROXY_PASSWORD}"
    },
    {
      "type": "direct",
      "tag": "do-out"
    },
    {
      "type": "dns",
      "tag": "dns-out"
    },
    {
      "type": "block",
      "tag": "block-out"
    }
  ],
  "route": {
    "rule_set": [
      {
        "tag": "geosite-youtube",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-youtube.srs",
        "download_detour": "do-out"
      },
      {
        "tag": "geosite-ads",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ads-all.srs",
        "download_detour": "do-out"
      }
    ],
    "rules": [
      {
        "protocol": "dns",
        "outbound": "dns-out"
      },
      {
        "rule_set": [ "geosite-ads" ],
        "action": "reject"
      },
      {
        "domain_suffix": [
          "github.com",
          "githubusercontent.com"
        ],
        "outbound": "do-out"
      },
      {
        "rule_set": [ "geosite-youtube" ],
        "outbound": "do-out"
      }
    ],
    "final": "portal-out"
  }
}
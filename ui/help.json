{
  "main_local": {
    "usage": "portal-local [command] [flags]",
    "description": "Portal Daemon background service with auto-recovery",
    "flags": [
      { "name": "-h, --help", "description": "help for portal-local" }
    ]
  },
  "install": {
    "usage": "portal-local install",
    "description": "Install the service to the system manager"
  },
  "start": {
    "usage": "portal-local start",
    "description": "Start the installed background service"
  },
  "stop": {
    "usage": "portal-local stop",
    "description": "Stop the background service"
  },
  "restart": {
    "usage": "portal-local restart",
    "description": "Restart the background service"
  },
  "uninstall": {
    "usage": "portal-local uninstall",
    "description": "Uninstall the service from the system manager"
  },
  "status": {
    "usage": "portal-local status",
    "description": "Query the current service status"
  },
  "logs": {
    "usage": "portal-local logs [flags]",
    "description": "View service logs",
    "flags": [
      { "name": "-f, --follow", "description": "Follow log output" },
      { "name": "-n, --lines int", "description": "Number of lines to show (default 100)" },
      { "name": "-h, --help", "description": "help for logs" }
    ]
  },
  "generate": {
    "usage": "portal-local generate [flags] OR portal-svc generate [flags]",
    "description": "Generate configuration template and .env file",
    "flags": [
      { "name": "-h, --help", "description": "help for generate" }
    ]
  },
  "render": {
    "usage": "portal-local render [flags] OR portal-svc render [flags]",
    "description": "Render a configuration template with environment variables",
    "flags": [
      { "name": "--config string", "description": "Path to the input template file" },
      { "name": "--out string", "description": "Path to the output JSON file" },
      { "name": "--ci", "description": "Inject CI rules (ci-direct-out, disable auto_route)" },
      { "name": "--index-srs", "description": "Download and index .srs files to local srs/ folder" },
      { "name": "-h, --help", "description": "help for render" }
    ]
  },
  "tweak": {
    "usage": "portal-local tweak [flags]",
    "description": "Interactive TUI to modify configuration settings",
    "flags": [
      { "name": "--config string", "description": "Path to the input template file (default \"templates/local_config.tmpl.json\")" },
      { "name": "-h, --help", "description": "help for tweak" }
    ]
  },
  "main_remote": {
    "usage": "portal-svc [command] [flags]",
    "description": "Portal Remote Node background service",
    "flags": [
      { "name": "-h, --help", "description": "help for portal-svc" }
    ]
  }
}

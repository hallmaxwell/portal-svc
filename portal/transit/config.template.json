{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "inbounds": [
    {
      "type": "vless",
      "tag": "vless-in",
      "listen": "::",
      "listen_port": 443,
      "users": [
        {
          "uuid": "{UUID}",
          "flow": "xtls-rprx-vision"
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "www.microsoft.com",
        "reality": {
          "enabled": true,
          "handshake": {
            "server": "www.microsoft.com",
            "server_port": 443
          },
          "private_key": "{PRIVATE_KEY}",
          "short_id": ["{SHORT_ID}"]
        }
      },
      "sniff": true,
      "sniff_override_destination": true
    }
  ],
  "outbounds": [
    {
      "type": "socks",
      "tag": "iproyal-out",
      "server": "{PROXY_IP}",
      "server_port": "{PROXY_PORT}",
      "username": "{PROXY_USERNAME}",
      "password": "{PROXY_PASSWORD}"
    },
    {
      "type": "direct",
      "tag": "direct-out"
    },
    {
      "type": "block",
      "tag": "block-out"
    }
  ],
  "route": {
    "rule_set": [
      {
        "tag": "geosite-google",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-google.srs",
        "download_detour": "direct-out"
      },
      {
        "tag": "geosite-youtube",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-youtube.srs",
        "download_detour": "direct-out"
      },
      {
        "domain_suffix": [
            "jsdelivr.net",
            "githubusercontent.com",
            "github.com"
            ],
      "outbound": "direct-out"
      },
      {
        "tag": "geosite-ads",
        "type": "remote",
        "format": "binary",
        "url": "https://cdn.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-category-ads-all.srs",
        "download_detour": "direct-out"
      }
      
    ],
    "rules": [
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "rule_set": "geosite-ads",
        "action": "reject",
        "method": "drop"
      },
      {
        "rule_set": ["geosite-youtube"],
        "outbound": "direct-out"
      }
    ],
    "final": "iproyal-out"
  },
  "dns": {
    "servers": [
      {
        "tag": "google-dns",
        "type": "udp",
        "server": "8.8.8.8"
      }
    ],
    "final": "google-dns"
  }
}
